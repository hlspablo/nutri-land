{
  "name": "nutri-land",
  "version": "0.1.0",
  "private": true,
  "description": "Landing page Dr. Antônio Wellington — Medicina do Emagrecimento",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "serve": "npx --yes http-server . -p 5173 -c-1 -o /index.html",
    "dev": "npm run build:css && npm run serve"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13"
  }
}
